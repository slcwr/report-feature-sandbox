# 機能用 RDB（MySQL）への接続文字列。
# docker-compose 内では DATABASE_URL が compose 側から渡されるので、このファイルは
# コンテナ外（ホスト）から drizzle-kit などを直接実行したい時のサンプル。
#
# 本番は接続先を TiDB(TiDB Serverless 等) に差し替えるだけ。Drizzle のコードは共通。
DATABASE_URL=mysql://app:app@localhost:3306/app

# JWT 署名鍵（開発用サンプル。本番は十分長いランダム値にする）
JWT_SECRET=dev-secret-change-me
